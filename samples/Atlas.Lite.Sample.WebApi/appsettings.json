{
  "AtlasLite": {
    "Web": {
      "ApplicationName": "Atlas.Lite.Sample.WebApi",
      "AllowedOrigins": [],
      "EnableSwagger": true
    },
    "Logging": {
      "MinimumLevel": "Information",
      "Console": {
        "Enabled": true
      },
      "File": {
        "Enabled": false,
        "Path": "logs/atlas-lite-sample-.log"
      },
      "Seq": {
        "Enabled": false,
        "ServerUrl": ""
      },
      "SensitiveFields": [
        "password",
        "secret",
        "token",
        "authorization"
      ]
    },
    "Database": {
      "Provider": "Sqlite",
      "ConnectionString": "Data Source=atlas-lite-sample.db"
    },
    "Auth": {
      "Jwt": {
        "Issuer": "Atlas.Lite.Sample",
        "Audience": "Atlas.Lite.Sample",
        "Secret": "sample-development-secret-change-me-32",
        "ExpirationMinutes": 60,
        "ClockSkewSeconds": 30
      }
    },
    "Cache": {
      "Provider": "Memory",
      "DefaultExpirationSeconds": 300,
      "Redis": {
        "ConnectionString": ""
      }
    },
    "BackgroundTasks": {
      "Enabled": true,
      "IntervalSeconds": 300
    }
  }
}
