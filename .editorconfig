root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = crlf

[*.{yml,yaml}]
end_of_line = lf
indent_size = 2

[*.{json,md}]
indent_size = 2

[*.sln]
indent_style = tab

[*.cs]
indent_size = 4

[*.csproj]
indent_size = 2
