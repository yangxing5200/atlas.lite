{
  "AtlasLite": {
    "Database": {
      "Provider": "Sqlite",
      "ConnectionString": "Data Source=atlas-lite.db"
    },
    "Auth": {
      "Jwt": {
        "Issuer": "AtlasLiteTemplate",
        "Audience": "AtlasLiteTemplate",
        "Secret": "replace-with-at-least-32-characters",
        "ExpirationMinutes": 60
      }
    },
    "Cache": {
      "Provider": "Memory"
    }
  }
}
